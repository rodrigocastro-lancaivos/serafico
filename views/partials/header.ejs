<!DOCTYPE html>
<html>
  <head>
    <title>CoroinhasAPSNDB</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  </head>

  <body style="background-color: #f1f1f1;">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script src="/javascripts/login.js" defer></script>

    <div class="container-fluid">
      <div class="row vh-100">

        <aside class="col-2 d-flex flex-column align-items-center" style="background-color: rgb(24, 34, 88);">

  <nav class="sidebar d-flex flex-column align-items-center">

    <img src="images/logoCoroinhasReduzida.png" 
         alt="Imagem logo dos Coroinhas" 
         class="mt-5 mb-1"
         style="width: 110px; height: auto;">

    <h3 style="color: rgb(235, 235, 235);">Coroinhas APNSDB</h3>

    <small style="color: #d6d6d6;" class="text-center mb-5">
      Área Pastoral Nossa Senhora do Brasil
    </small>

    <a href="/home" class="btn <%= paginaAtiva === 'home' ? 'btn-danger' : 'btn-outline-light' %> w-100 mb-4">Início</a>
    <a href="/coroinhas" class="btn <%= paginaAtiva === 'coroinhas' ? 'btn-danger' : 'btn-outline-light' %> w-100 mb-4">Coroinhas</a>
    <a href="/escala" class="btn <%= paginaAtiva === 'escala' ? 'btn-danger' : 'btn-outline-light' %> w-100 mb-4">Escala</a>
    <a href="/configuracoes" class="btn <%= paginaAtiva === 'configuracoes' ? 'btn-danger' : 'btn-outline-light' %> w-100 mb-4">Configurações</a>

    <a href="/users" class="<%= paginaAtiva === 'sair' ? 'btn btn-danger' : 'btn btn-outline-light' %> w-100 mb-4">
      <%= perfil ? perfil : 'Perfil' %>
